# ── Neo4j AuraDB ─────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── DeepSeek LLM ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_KEYS=key1,key2,key3
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Tavily web search ─────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── LlamaParse (CV PDF parsing) ───────────────────────────────────────────────
LLAMA_CLOUD_API_KEY=

# ── Google Drive (CV storage) ─────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/google_service_account.json
GDRIVE_ROOT_FOLDER_ID=

# ── Google Sheet webhook (intake form) ───────────────────────────────────────
GOOGLE_SHEET_WEBHOOK=

# ── NestJS Gateway ───────────────────────────────────────────────────────────
# AI_SERVICE_URL is overridden by docker-compose to http://api:8000
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=120000
PORT=3000
JWT_SECRET=change-me-in-production
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# ── Facebook Messenger ───────────────────────────────────────────────────────
FB_PAGE_ACCESS_TOKEN=
FB_APP_SECRET=
FB_VERIFY_TOKEN=my_lnc_verify_token_2024

# ── Legacy / unused ──────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=
HUGGINGFACE_API_KEY=
